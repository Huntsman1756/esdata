[Unit]
Description=esdata read-only MCP validation suite
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=deploy
Group=deploy
WorkingDirectory=/srv/esdata
EnvironmentFile=/etc/esdata/esdata.env
TimeoutStartSec=10m
ExecStart=/usr/bin/python3 /srv/esdata/scripts/maintenance/mcp_validation_suite.py --read-only --base-url http://127.0.0.1:8000
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
