FROM python:3.12-slim@sha256:46cb7cc2877e60fbd5e21a9ae6115c30ace7a077b9f8772da879e4590c18c2e3

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

RUN pip install --no-cache-dir \
    alembic==1.16.4 \
    httpx==0.28.1 \
    pydantic==2.13.4 \
    sqlalchemy==2.0.43 \
    psycopg[binary]==3.2.9

COPY alembic.ini /workspace/alembic.ini
COPY alembic /workspace/alembic
COPY scripts /workspace/scripts
COPY scripts/maintenance/mcp_validation_suite.py /workspace/mcp_validation_suite.py
COPY scripts/maintenance/mcp_deep_contract_audit.py /workspace/mcp_deep_contract_audit.py
COPY apps/api/mcp_*.py /workspace/apps/api/

CMD ["python", "--version"]
