# Copy to `.env.prod` next to `docker-compose.prod.yml` for deployment.

POSTGRES_USER=esdata
POSTGRES_PASSWORD=change-me
POSTGRES_DB=esdata
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1

DATABASE_URL=postgresql+psycopg://esdata:change-me@postgres:5432/esdata

API_PORT=8000
WEB_PORT=3000
API_BIND_ADDRESS=127.0.0.1
WEB_BIND_ADDRESS=127.0.0.1
ESDATA_API_BASE_URL=http://api:8000
ESDATA_API_URL=http://api:8000
APP_ENV=production
ESDATA_API_KEY=change-me-api-key
API_DOMAIN=api.esdata.es
WEB_DOMAIN=esdata.es
CADDY_EMAIL=admin@example.com
MCP_API_KEY=change-me-mcp-key
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
GRAFANA_ROOT_URL=https://tudominio.com/grafana/

BOE_API_BASE=https://www.boe.es/datosabiertos/api/legislacion-consolidada
BOE_LEGISLACION_NORMAS=LIVA,LIRPF,LIS,LGT,ITPAJD,IRNR,IIEE,HL,DAC6,DAC6RD,DAC6EU
BOE_SYNC_INTERVAL_SECONDS=3600
BOE_DIARIO_IDS=
BOE_DIARIO_DAYS_BACK=1
BOE_DIARIO_MAX_IDS_PER_RUN=10
BOE_DIARIO_FETCH_PDF_FALLBACK=true
BDNS_SEED_URLS=https://www.infosubvenciones.es/bdnstrans/GE/es/convocatoria/749075/document/1034404
BDNS_SYNC_INTERVAL_SECONDS=604800
BORME_SEED_URLS=https://www.boe.es/borme/dias/2025/03/20/pdfs/BORME-A-2025-55-37.pdf
BORME_SYNC_INTERVAL_SECONDS=604800
CNMV_SEED_URLS=https://www.boe.es/buscar/doc.php?id=BOE-A-2009-133
CNMV_SYNC_INTERVAL_SECONDS=604800
SEPBLAC_SEED_URLS=https://www.sepblac.es/es/,https://www.sepblac.es/es/publicaciones/
SEPBLAC_SYNC_INTERVAL_SECONDS=604800
CENDOJ_SEED_URLS=https://www.poderjudicial.es/search/indexAN.jsp
CENDOJ_SYNC_INTERVAL_SECONDS=604800
BDE_SEED_URLS=https://www.bde.es/wbe/es/publicaciones/informacion-estadistica/
BDE_SYNC_INTERVAL_SECONDS=604800
AEPD_SEED_URLS=https://www.boe.es/buscar/act.php?id=BOE-A-2018-16673
AEPD_SYNC_INTERVAL_SECONDS=604800

DGT_SSL_VERIFY=false
DGT_DISCOVERY=true
DGT_SYNC_INTERVAL_SECONDS=604800

TEAC_SEED_URLS=https://serviciostelematicosext.hacienda.gob.es/TEAC/DYCTEA/
TEAC_SYNC_INTERVAL_SECONDS=604800

MODELOS_SYNC_INTERVAL=86400
BOE_MODELOS_SYNC_INTERVAL=86400
EURLEX_SEED_URLS=
EURLEX_SYNC_INTERVAL_SECONDS=604800
SPARQL_BASE=https://data.europa.eu/sparql
CDI_SYNC_INTERVAL_SECONDS=604800
WORKER_REQUEST_DELAY=1.0
HERMES_MONITOR_INTERVAL=300
HERMES_AUTO_RESTART_ENABLED=false
HERMES_RESTART_ALLOWLIST=worker-boe,worker-eurlex,worker-dgt

# Telegram alerts are configured through secret files, not env vars:
#   infra/deploy/secrets/alertmanager/telegram_bot_token
# The chat id is not a bot token; Alertmanager v0.28.1 receives it through env.
TELEGRAM_CHAT_ID=123456789

