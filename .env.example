# Variables de entorno canónicas de esdata.
# Este archivo prioriza el runtime y la operación reales del repo actual.
# Ver detalle y clasificación completa en `docs/environment-variables.md`.

# ============================================================
# Producción — variables requeridas
# ============================================================

# --- Base de datos ---
POSTGRES_USER=esdata
POSTGRES_PASSWORD=<contraseña_segura>
POSTGRES_DB=esdata
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Dominios (Caddy) ---
API_DOMAIN=api.tudominio.com
WEB_DOMAIN=tudominio.com
CADDY_EMAIL=tuemail@ejemplo.com

# --- Bind addresses (solo producción) ---
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

# --- Frontend web ---
ESDATA_API_BASE_URL=https://api.tudominio.com

# --- API / operación general ---
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=text
ESDATA_CORS_ORIGINS=https://tudominio.com,https://api.tudominio.com
ESDATA_API_KEY=<api_key_obligatoria>
ESDATA_RATE_LIMIT_ENABLED=true
ESDATA_HSTS_ENABLED=true
ESDATA_SENTRY_DSN=

# --- BOE ---
BOE_API_BASE=https://www.boe.es/datosabiertos/api/legislacion-consolidada
BOE_LEGISLACION_NORMAS=LIVA,LIRPF,LIS,LGT,ITPAJD,IRNR,IIEE,HL,DAC6,DAC6RD,DAC6EU
SYNC_INTERVAL_SECONDS=3600
BOE_SYNC_INTERVAL_SECONDS=3600
BOE_ONLY_BLOCK_IDS=

# --- Fuentes externas ---
BDNS_SEED_URLS=
BORME_SEED_URLS=
CNMV_SEED_URLS=https://www.boe.es/buscar/doc.php?id=BOE-A-2009-133
SEPBLAC_SEED_URLS=https://www.sepblac.es/es/,https://www.sepblac.es/es/publicaciones/
CENDOJ_SEED_URLS=
EURLEX_SEED_URLS=
BDE_SEED_URLS=https://www.bde.es/wbe/es/publicaciones/informacion-estadistica/
AEPD_SEED_URLS=

BDNS_SYNC_INTERVAL_SECONDS=604800
BORME_SYNC_INTERVAL_SECONDS=604800
CNMV_SYNC_INTERVAL_SECONDS=604800
SEPBLAC_SYNC_INTERVAL_SECONDS=604800
CENDOJ_SYNC_INTERVAL_SECONDS=604800
EURLEX_SYNC_INTERVAL_SECONDS=604800
BDE_SYNC_INTERVAL_SECONDS=604800
AEPD_SYNC_INTERVAL_SECONDS=604800

# --- DGT ---
DGT_SSL_VERIFY=true
DGT_SYNC_INTERVAL_SECONDS=604800

# --- TEAC ---
TEAC_SEED_URLS=
TEAC_SYNC_INTERVAL_SECONDS=604800

# --- Modelos AEAT ---
MODELOS_SYNC_INTERVAL=86400

# --- Cloudflare / MCP perimetral ---
MCP_API_KEY=<mcp_api_key_obligatoria>
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_SECRET_ACTIVE=
MCP_SECRET_PREVIOUS=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# --- Agent monitor ---
AGENT_MONITOR_ENABLED=false
AGENT_MONITOR_INTERVAL=300
AGENT_MONITOR_ENTIDAD=sociedad_valores
AGENT_MONITOR_PRIORIDAD=media

# --- Scripts auxiliares ---
DATABASE_PUBLIC_URL=

# --- Variables opcionales (no usadas por el runtime principal) ---
REDIS_URL=
SECRET_KEY=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
SLACK_WEBHOOK_URL=
