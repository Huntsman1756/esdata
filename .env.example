# Variables de entorno canónicas de esdata.
# Este archivo prioriza el runtime y la operación reales del repo actual.
# Ver detalle y clasificación completa en `docs/environment-variables.md`.

# --- Runtime compartido ---
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# --- Frontend web ---
ESDATA_API_BASE_URL=http://localhost:8000

# --- API / operación general ---
APP_ENV=development

# --- BOE ---
BOE_API_BASE=https://www.boe.es/datosabiertos/api/legislacion-consolidada
BOE_LEGISLACION_NORMAS=LIVA,LIRPF,LIS,LGT,ITPAJD
SYNC_INTERVAL_SECONDS=3600
BOE_ONLY_BLOCK_IDS=

# --- DGT ---
# En `apps/workers/dgt.py`, `true|1|yes` activa verify SSL.
DGT_SSL_VERIFY=false

# --- TEAC ---
TEAC_SEED_URLS=

# --- Modelos AEAT ---
MODELOS_SYNC_INTERVAL=86400

# --- Scripts auxiliares ---
DATABASE_PUBLIC_URL=

# --- Cloudflare / MCP perimetral ---
MCP_SECRET_ACTIVE=
MCP_SECRET_PREVIOUS=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# --- Variables hoy documentadas pero no usadas por el runtime principal ---
REDIS_URL=
SECRET_KEY=
LOG_LEVEL=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
SLACK_WEBHOOK_URL=
