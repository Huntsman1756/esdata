# Inventario amplio de variables de entorno de esdata.
# No es la plantilla operativa del deploy Compose activo.
# Para el despliegue Docker Compose activo usar solo `infra/deploy/compose.env.example`
# y copiarlo a `/etc/esdata/esdata.env` fuera del checkout.
# Ver detalle y clasificacion completa en `docs/environment-variables.md`.

# ============================================================
# Inventario base de variables frecuentes
# ============================================================

# --- Base de datos ---
POSTGRES_USER=esdata
POSTGRES_PASSWORD=<contraseña_segura>
POSTGRES_DB=esdata
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Dominios (Caddy) ---
API_DOMAIN=api.tudominio.com
WEB_DOMAIN=tudominio.com
CADDY_EMAIL=tuemail@ejemplo.com

# --- Bind addresses (solo producción) ---
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

# --- Frontend web ---
ESDATA_API_BASE_URL=https://api.tudominio.com

# --- API / operación general ---
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=text
ESDATA_CORS_ORIGINS=https://tudominio.com,https://api.tudominio.com
ESDATA_API_KEY=<api_key_obligatoria>
ESDATA_RATE_LIMIT_ENABLED=true
ESDATA_HSTS_ENABLED=true
ESDATA_SENTRY_DSN=

# --- BOE ---
BOE_API_BASE=https://www.boe.es/datosabiertos/api/legislacion-consolidada
BOE_LEGISLACION_NORMAS=LIVA,LIRPF,LIS,LGT,ITPAJD,TRLIRNR,LEY10_2010,RDL19_2018,LIVMC,RD_1082_2012,RD_813_2023,IRNR,IIEE,HL,DAC6,DAC6RD,DAC6EU
SYNC_INTERVAL_SECONDS=3600
BOE_SYNC_INTERVAL_SECONDS=3600
BOE_ONLY_BLOCK_IDS=
BOE_DIARIO_IDS=
BOE_DIARIO_DAYS_BACK=1
BOE_DIARIO_MAX_IDS_PER_RUN=10
BOE_DIARIO_FETCH_PDF_FALLBACK=true

# --- Fuentes externas ---
BDNS_SEED_URLS=https://www.infosubvenciones.es/bdnstrans/GE/es/convocatoria/749075/document/1034404
BORME_SEED_URLS=https://www.boe.es/borme/dias/2025/03/20/pdfs/BORME-A-2025-55-37.pdf
CNMV_SEED_URLS=https://www.boe.es/buscar/doc.php?id=BOE-A-2009-133
SEPBLAC_SEED_URLS=https://www.sepblac.es/es/normativa/?lang=es,https://www.sepblac.es/es/normativa/normativa-nacional/,https://www.sepblac.es/es/normativa/normativa-comunitaria/,https://www.sepblac.es/es/sujetos-obligados/obligaciones/
EU_SANCTIONS_XML_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content
CENDOJ_SEED_URLS=https://www.poderjudicial.es/search/indexAN.jsp
EURLEX_SEED_URLS=https://eur-lex.europa.eu/legal-content/ES/TXT/?uri=CELEX:32016R0679
SPARQL_BASE=https://data.europa.eu/sparql
BDE_SEED_URLS=https://www.bde.es/wbe/es/publicaciones/informacion-estadistica/
AEPD_SEED_URLS=https://www.boe.es/buscar/act.php?id=BOE-A-2018-16673

BDNS_SYNC_INTERVAL_SECONDS=604800
BORME_SYNC_INTERVAL_SECONDS=604800
CNMV_SYNC_INTERVAL_SECONDS=604800
SEPBLAC_SYNC_INTERVAL_SECONDS=604800
CENDOJ_SYNC_INTERVAL_SECONDS=604800
EURLEX_SYNC_INTERVAL_SECONDS=604800
BDE_SYNC_INTERVAL_SECONDS=604800
AEPD_SYNC_INTERVAL_SECONDS=604800

# --- DGT ---
DGT_SSL_VERIFY=false
DGT_DISCOVERY=true
DGT_SYNC_INTERVAL_SECONDS=604800

# --- TEAC ---
TEAC_SEED_URLS=https://serviciostelematicosext.hacienda.gob.es/TEAC/DYCTEA/
TEAC_SYNC_INTERVAL_SECONDS=604800

# --- Modelos AEAT ---
MODELOS_SYNC_INTERVAL=86400

# --- Cloudflare / MCP perimetral ---
MCP_API_KEY=<mcp_api_key_obligatoria>
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_SECRET_ACTIVE=
MCP_SECRET_PREVIOUS=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# --- Agent monitor ---
AGENT_MONITOR_ENABLED=false
AGENT_MONITOR_INTERVAL=300
AGENT_MONITOR_ENTIDAD=sociedad_valores
AGENT_MONITOR_PRIORIDAD=media

# --- Scripts auxiliares ---
DATABASE_PUBLIC_URL=

# --- Variables opcionales (no usadas por el runtime principal) ---
REDIS_URL=
SECRET_KEY=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
SLACK_WEBHOOK_URL=

# ============================================================
# Pool de conexiones SQLAlchemy (ajustar si se excede max_connections)
# ============================================================
# Cada servicio (API + workers) crea su propio pool.
# Con 14 servicios: total max = 14 × (pool_size + max_overflow).
# PostgreSQL default max_connections = 100.
#
# Default seguro: 14 × (5 + 10) = 210 conexiones máx teóricas,
# pero en práctica casi nunca se usan todas simultáneamente.
# Si ves "too many connections", reducir a pool_size=3, max_overflow=5.
#
# pool_recycle: reciclo conexiones después de N segundos para
# evitar stale connections tras restart de PostgreSQL.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=20
DB_POOL_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# ============================================================
# Rate limiting entre requests de workers (segundos)
# ============================================================
# Se aplica entre requests consecutivos al mismo dominio.
# Previene bans por scraping agresivo en AEAT, BOE, TEAC, etc.
# Cada worker aplica delay independiente — no afecta a otros workers.
WORKER_REQUEST_DELAY=1.0

# ============================================================
# Prometheus /metrics endpoint
# ============================================================
# El endpoint /metrics es público en la API (sin auth).
# En producción, protege con:
#   - Firewall: solo accesible desde la red de monitoring
#   - Reverse proxy: restricción por IP en Caddy/Nginx
# No existe hoy una env var activa en runtime para cerrar `/metrics` por sí sola.
# Si necesitas cambiar ese comportamiento, tratarlo como trabajo de código + docs.

# --- Healthchecks cron (opcional, recomendado en produccion) ---
HC_PING_URL_CRON_BOE_DAILY=
HC_PING_URL_CRON_BOE_DIARIO_DAILY=
HC_PING_URL_CRON_DGT_WEEKLY=
HC_PING_URL_CRON_TEAC_WEEKLY=
HC_PING_URL_CRON_MODELOS_DAILY=
HC_PING_URL_CRON_AEAT_CURRENT_DAILY=
HC_PING_URL_CRON_BDNS_WEEKLY=
HC_PING_URL_CRON_BORME_WEEKLY=
HC_PING_URL_CRON_CNMV_WEEKLY=
HC_PING_URL_CRON_SEPBLAC_WEEKLY=
HC_PING_URL_CRON_BDE_WEEKLY=

# ============================================================
# Grafana (observabilidad)
# ============================================================
# Contraseña de admin de Grafana — obligatoria, sin default.
# Cambiar antes de desplegar en producción.
GRAFANA_ADMIN_PASSWORD=<contraseña_segura>
# URL base de Grafana — debe coincidir con el path de Caddy (/grafana*)
GRAFANA_ROOT_URL=https://tudominio.com/grafana/
