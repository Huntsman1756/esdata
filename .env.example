# ============================================================
# VARIABLES DE ENTORNO — esdata
# ============================================================
# IMPORTANTE: Railway inyecta automáticamente las variables de
# Postgres y Redis en los servicios conectados. NO copies estas
# variables en GitHub Secrets salvo que las necesites para jobs
# externos al entorno Railway (ver ci.yml para el caso de CI).
# ============================================================

# === PostgreSQL (Railway las inyecta automáticamente) ===
# En local, define estas manualmente o usa docker-compose.
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=

# === Redis (opcional, para colas de webhooks) ===
REDIS_URL=redis://user:password@host:6379

# === API ===
APP_ENV=production             # production | staging | development
SECRET_KEY=generar_con_openssl_rand_hex_32
LOG_LEVEL=INFO

# === Workers ===
BOE_API_BASE=https://www.boe.es/datosabiertos/api
BOE_LEGISLACION_NORMAS=LIVA,LIRPF,LIS,LGT,ITPAJD
WORKER_BOE_BATCH_SIZE=10
WORKER_RETRY_MAX=3
WORKER_RETRY_BACKOFF_SECONDS=30

# === Doctrina DGT ===
DGT_BASE_URL=https://petete.tributos.hacienda.gob.es
DGT_REQUEST_DELAY_SECONDS=2

# === MCP — rotación de secretos ===
# Dos secretos permiten rotación sin downtime:
# - MCP_SECRET_ACTIVE: el que aceptas ahora
# - MCP_SECRET_PREVIOUS: el anterior, válido durante el periodo de gracia
# Para rotar: el nuevo pasa a ACTIVE, el viejo a PREVIOUS.
# Tras 24h, borra PREVIOUS.
MCP_SECRET_ACTIVE=generar_con_openssl_rand_hex_32
MCP_SECRET_PREVIOUS=            # vacío si no hay rotación en curso

# === Cloudflare (purge de caché en deploys) ===
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=           # permisos: Cache Purge

# === Alertas ===
SLACK_WEBHOOK_URL=              # notificaciones de errores de worker
