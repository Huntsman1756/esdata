{
  "openapi": "3.1.0",
  "info": {
    "title": "esdata API",
    "description": "API de consulta de legislacion espanola consolidada, doctrina interpretativa y modelos tributarios AEAT. Permite buscar articulos por texto, consultar normas, doctrina (DGT, TEAC) y obtener casillas, claves e instrucciones de modelos fiscales.",
    "version": "0.1.6"
  },
  "servers": [
    {
      "url": "https://esdata-production.up.railway.app",
      "description": "Production API on Railway"
    }
  ],
  "paths": {
    "/v1/legislacion/buscar": {
      "get": {
        "tags": [
          "buscar"
        ],
        "summary": "Search Spanish legislation by text",
        "operationId": "buscar_legislacion",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Termino de busqueda",
              "title": "Q"
            },
            "description": "Termino de busqueda"
          },
          {
            "name": "norma",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filtrar por codigo de norma",
              "title": "Norma"
            },
            "description": "Filtrar por codigo de norma"
          },
          {
            "name": "fuente",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filtrar por fuente",
              "title": "Fuente"
            },
            "description": "Filtrar por fuente"
          },
          {
            "name": "ambito",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filtrar por ambito",
              "title": "Ambito"
            },
            "description": "Filtrar por ambito"
          },
          {
            "name": "tipo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filtrar por tipo de articulo",
              "title": "Tipo"
            },
            "description": "Filtrar por tipo de articulo"
          },
          {
            "name": "vigente_en",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Fecha de vigencia (YYYY-MM-DD)",
              "title": "Vigente En"
            },
            "description": "Fecha de vigencia (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LegislacionSearchResponse"
                }
              }
            }
          }
        },
        "description": "Search consolidated Spanish laws (LIVA, LIRPF, LIS, etc.) by keyword. Returns matching articles with snippets and relevance scores. Filter by norma (e.g. LIVA, LIRPF), ambito, tipo, fuente, or vigencia."
      }
    },
    "/v1/legislacion/{codigo}": {
      "get": {
        "tags": [
          "legislacion"
        ],
        "summary": "Get law details",
        "operationId": "get_norma",
        "parameters": [
          {
            "name": "codigo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Codigo"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Norma"
                }
              }
            }
          }
        },
        "description": "Get metadata for a Spanish law by code (e.g. LIVA, LIRPF, LIS). Returns title, jurisdiction, document type, and coverage status."
      }
    },
    "/v1/legislacion/{codigo}/articulos/{numero}": {
      "get": {
        "tags": [
          "legislacion"
        ],
        "summary": "Get article text",
        "operationId": "get_articulo",
        "parameters": [
          {
            "name": "codigo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Codigo"
            }
          },
          {
            "name": "numero",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Numero"
            }
          },
          {
            "name": "vigente_en",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Fecha de vigencia (YYYY-MM-DD)",
              "title": "Vigente En"
            },
            "description": "Fecha de vigencia (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticuloDetail"
                }
              }
            }
          }
        },
        "description": "Get the full text of a specific article from a law. Optionally filter by vigencia_en (YYYY-MM-DD) for historical versions. Returns the article text, validity dates, and confidence info."
      }
    },
    "/v1/doctrina/buscar": {
      "get": {
        "tags": [
          "doctrina"
        ],
        "summary": "Search interpretative doctrine",
        "operationId": "buscar_doctrina",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Termino de busqueda en texto de doctrina",
              "title": "Q"
            },
            "description": "Termino de busqueda en texto de doctrina"
          },
          {
            "name": "tipo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filtrar por tipo (consulta_vinculante, resolucion_teac, etc.)",
              "title": "Tipo"
            },
            "description": "Filtrar por tipo (consulta_vinculante, resolucion_teac, etc.)"
          },
          {
            "name": "desde",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Fecha minima (YYYY-MM-DD)",
              "title": "Desde"
            },
            "description": "Fecha minima (YYYY-MM-DD)"
          },
          {
            "name": "organismo_emisor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Filtrar por organismo (DGT, TEAC, etc.)",
              "title": "Organismo Emisor"
            },
            "description": "Filtrar por organismo (DGT, TEAC, etc.)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DoctrinaSearchResponse"
                }
              }
            }
          }
        },
        "description": "Search interpretative doctrine from DGT (binding queries) or TEAC (resolutions). Returns doctrine documents with linked articles and confidence scores. Filter by tipo (consulta_vinculante, resolucion_teac), organismo_emisor, or fecha."
      }
    },
    "/v1/doctrina/{referencia}": {
      "get": {
        "tags": [
          "doctrina"
        ],
        "summary": "Get doctrine document",
        "operationId": "get_doctrina",
        "parameters": [
          {
            "name": "referencia",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Referencia"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DoctrinaDetail"
                }
              }
            }
          }
        },
        "description": "Get a specific doctrine document by reference (e.g. V0000-26, 00/1234/2024). Returns full text, linked articles, and confidence information."
      }
    },
    "/v1/modelos": {
      "get": {
        "tags": [
          "modelos"
        ],
        "summary": "List AEAT tax models",
        "description": "List all AEAT tax form models (100, 303, 111, etc.) with their linked article counts and active campaign box counts.",
        "operationId": "list_modelos",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelosListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/modelos/{codigo}": {
      "get": {
        "tags": [
          "modelos"
        ],
        "summary": "Get AEAT model details",
        "description": "Get full details for a specific AEAT tax model including linked legislation articles, active campaign boxes (casillas), key codes (claves), step-by-step instructions, regulatory framework (normativa), and related doctrine.",
        "operationId": "get_modelo",
        "parameters": [
          {
            "name": "codigo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Codigo"
            }
          },
          {
            "name": "campana",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Campana especifica (ej: 2025). Si no se indica, usa la activa.",
              "title": "Campana"
            },
            "description": "Campana especifica (ej: 2025). Si no se indica, usa la activa."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModeloDetail"
                }
              }
            }
          }
        }
      }
    }
  },
